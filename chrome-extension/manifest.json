{
  "manifest_version": 3,
  "name": "TalkNote – Meeting Recorder",
  "version": "1.0.0",
  "description": "Record meetings from Google Meet, Zoom, or any tab. AI-powered transcription, summaries, and tasks.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://capstone-project-delta-nine.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://capstone-project-delta-nine.vercel.app/*"
      ],
      "js": ["auth_bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
